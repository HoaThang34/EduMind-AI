SECRET_KEY=your_secret_key_here
# Tên model trùng với `ollama list` (vd: llama3.2, mistral). Không dùng tên Gemini Google cho Ollama mặc định.
OLLAMA_MODEL=llama3.2
# Model dự phòng khi model chính lỗi / chưa pull (cùng host Ollama).
OLLAMA_FALLBACK_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
# Tuỳ chọn: model riêng cho API báo cáo hành vi (mặc định = OLLAMA_MODEL).
# OLLAMA_TEXT_MODEL=
